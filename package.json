{
  "name": "backend-core",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "concurrently \"node server.js\" \"node src/workers/audioWorker.js\" \"node src/workers/feedWorker.js\"",
    "dev": "concurrently \"nodemon server.js\" \"nodemon src/workers/audioWorker.js\" \"nodemon src/workers/feedWorker.js\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest --coverage --forceExit --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "collectCoverageFrom": [
      "src/services/**/*.js",
      "src/controllers/**/*.js",
      "src/middlewares/**/*.js",
      "src/utils/appError.js",
      "src/utils/catchAsync.js",
      "src/utils/sendEmail.js",
      "src/utils/audioUtils.js",
      "src/utils/azureStorage.js",
      "src/utils/cronJobs.js",
      "src/utils/queueProducer.js",
      "src/validations/**/*.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.9",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.1",
    "fluent-ffmpeg": "^2.1.3",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.21.0",
    "mongoose": "^8.23.0",
    "mongoose-slug-updater": "^3.3.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^22.0.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1"
  }
}
